ai.steamstatic.com/store_item_assets/steam/apps/1850270/extras/5c049764184c258cf2d9dc61d6e9a3c9.mp4?t=1776915295\" type=\"video/mp4\"></video></span><h2 class=\"bb_tag\" >◆背景故事</h2><br>我，宮口直人，一名大齡家裡蹲母胎單身直男駭客，發明出了一台堪稱神奇的機器——夢境機器。<br>它雖然破舊得如同廢品回收站裡的古董垃圾，卻能接收夢境信號並通過處理還原出夢境的樣子，實現觀測他人夢境的效果<br>如果僅僅只是這樣的話也沒有什麼特別的用處，重點是，只要暴力破解出夢境的金鑰，它就能製造出干涉信號，影響夢境，實現與夢境的交互，真正地達到進入夢境的效果。<br><br><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1850270/extras/a765a3787e3e659b80ed06dc1e36d21e.poster.avif?t=1776915295\" width=600 height=338 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1850270/extras/a765a3787e3e659b80ed06dc1e36d21e.webm?t=1776915295\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1850270/extras/a765a3787e3e659b80ed06dc1e36d21e.mp4?t=1776915295\" type=\"video/mp4\"></video></span><br><br>於是已經29歲卻仍是處男的我，沒有絲毫猶豫，開始了尋找美少女夢境的行動……<br>一場豔遇之旅，就此開啟。 <br><br><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1850270/extras/e7eb0a08a1e03637558df7a32e248044.avif?t=1776915295\" width=598 height=336 /></span><h2 class=\"bb_tag\" >◆遊戲特色</h2><br>◇5位個性迥異的女主<br>◇11張可自由操控的live2d動態CG，包含各種H Play，玩法豐富<br>◇獨具特色的打字消除玩法，以及16種特殊的單詞屬性<br>◇開放創意工坊，可以自由下載或上傳單詞<h2 class=\"bb_tag\" >◆如何進入工作坊◆</h2><br><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1850270/extras/72addb1d295d9660d6e8511f46afa747.avif?t=1776915295\" width=614 height=246 /></span><br><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1850270/extras/e042af54f017760c9167218950f415cc.avif?t=1776915295\" width=614 height=162 /></span>", "about_the_game": "<span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop pla