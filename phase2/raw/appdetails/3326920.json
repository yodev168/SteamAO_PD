mai.steamstatic.com/store_item_assets/steam/apps/3326920/8efe924b6cbc7597ca527c870379560bb5dff124/capsule_184x69_tchinese.jpg?t=1762827506", "website": "https://072project.com/?source=steam_natsumi_academy&amp;utm_source=steam&amp;utm_medium=natsumi_academy&amp;utm_campaign=store_link", "pc_requirements": {"minimum": "<strong>最低配備:</strong><br><ul class=\"bb_ul\"><li><strong>作業系統 *:</strong> Windows® 7/8/8.1/10/11<br></li><li><strong>處理器:</strong> Intel Core2 Duo or better<br></li><li><strong>顯示卡:</strong> DirectX 9/OpenGL 4.1 capable GPU<br></li><li><strong>儲存空間:</strong> 2 GB 可用空間</li></ul>", "recommended": "<strong>建議配備:</strong><br><ul class=\"bb_ul\"><li><strong>作業系統 *:</strong> Windows® 7/8/8.1/10/11<br></li><li><strong>處理器:</strong> 2+ GHz Processor<br></li><li><strong>記憶體:</strong> 4 GB 記憶體<br></li><li><strong>顯示卡:</strong> OpenGL ES 2.0 hardware driver support required for WebGL acceleration. (AMD Catalyst 10.9, nVidia 358.50)<br></li><li><strong>儲存空間:</strong> 4 GB 可用空間</li></ul>"}, "mac_requirements": [], "linux_requirements": [], "developers": ["スタジオツンエクゼ"], "publishers": ["072 Project", "072 News"], "price_overview": {"currency": "TWD", "initial": 23800, "final": 18500, "discount_percent": 22, "initial_formatted": "NT$ 238", "final_formatted": "NT$ 185"}, "categories": [{"id": 2, "description": "單人"}, {"id": 22, "description": "Steam 成就"}, {"id": 23, "description": "Steam 雲端"}, {"id": 62, "description": "親友同享"}], "genres": [{"id": "4", "description": "休閒"}, {"id": "23", "description": "獨立製作"}, {"id": "3", "description": "角色扮演"}], "release_date": {"coming_soon": false, "date": "2025 年 5 月 23 日"}}}}, "us": {"3326920": {"success": true, "data": {"type": "game", "name": "Natsumi and the Absurd Academy", "steam_appid": 3326920, "required_age": 0, "is_free": false, "detailed_description": "<h2 class=\"bb_tag\" ><strong>【Summary】</strong></h2><p class=\"bb_paragraph\" ><i><strong>What on earth is this school?! </strong></i> </p><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3326920/extras/e3c7e7affbee9a1bb9523966f90b4832.avif?t=1762827506\" width=600 height=454 /></span></p><p class=\"bb_paragraph\" >Weird encounters happened to Natsumi on the first day of her transference</p><p class=\"bb_paragraph\" >The Counseling Teacher looking for trouble, the Principal with religious fanaticism, and Classmates with absurd common sense ...</p><p class=\"bb_paragraph\" >Meeting classmates and teachers with unique personalities at the start of the semester, can she get used to school life from now on?</p><h2 class=\"bb_tag\" ><strong>【Controls】</strong></h2><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3326920/extras/bdd67ffb76f3c890754c321ca31f341b.avif?t=1762827506\" width=600 height=439 /></span>▲Game Objective: Players must increase their intelligence and stamina to at least 20 within 20 days!</p><p class=\"bb_paragraph\" >  </p><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3326920/extras/12ee925355d8b0aebc24cddece4c0105.poster.avif?t=1762827506\" width=600 height=458 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3326920/extras/12ee925355d8b0aebc24cddece4c0105.webm?t=1762827506\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3326920/extras/12ee925355d8b0aebc24cddece4c0105.mp4?t=1762827506\" type=\"video/mp4\"></video></span></p><p class=\"bb_paragraph\" >▲Use arrow keys to control Natsumi and use the Z key to interact with classmates and teachers!</p><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3326920/extras/b083b97e684d422a0fde841e2f89a0f2.poster.avif?t=1762827506\" width=600 height=458 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3326920/extras/b083b97e684d422a0fde841e2f89a0f2.webm?t=1762827506\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3326920/extras/b083b97e684d422a0fde841e2f89a0f2.mp4?t=1762827506\" type=\"video/mp4\"></video></span></p><p class=\"bb_paragraph\" >▲Attend classes and increase knowledge!<br>Although sometimes it might be a self-study period ...?</p><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3326920/extras/b75039e8bbd02e8031c532d0841d677d.avif?t=1762827506\" width=600 height=460 /></span></p><p class=\"bb_paragraph\" >▲Because this is an absurd academy, sparring with classmates is a compulsory subject!</p><p class=\"bb_paragraph\" ></p><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3326920/extras/b6ad5f1a445b607cc7b5f1f62ad4c753.avif?t=1762827506\" width=600 height=454 /></span></p><p class=\"bb_paragraph\" >▲Utilize each function in the academy to its best to improve your abilities!</p><h2 class=\"bb_tag\" ><strong>【Protagonist】</strong></h2><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3326920/extras/6d0d79ef46176f25cd6085d2f16c5b90.avif?t=1762827506\" width=254 height=252 /></span></p><p class=\"bb_paragraph\" >▲Natsumi</p><p class=\"bb_paragraph\" >A normal girl. She is living with her granny because her father is working abroad.She just transferred to a new school and is quite nervous.</p><h2 class=\"bb_tag\" ><strong>【Side Characters】</strong></h2><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3326920/extras/e710bf3bf944b8f21b5261576c7f392d.avif?t=1762827506\" width=600 height=438 /></span></p>", "about_the_game": "<h2 class=\"bb_tag\" ><strong>【Summary】</strong></h2><p class=\"bb_paragraph\" ><i><strong>What on earth is this school?! </strong></i> </p><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3326920/extras/e3c7e7affbee9a1bb9523966f90b4832.avif?t=1762827506\" width=600 height=454 /></span></p><p class=\"bb_paragraph\" >Weird encounters happened to Natsumi on the first day of her transference</p><p class=\"bb_paragraph\" >The Counseling Teacher looking for trouble, the Principal with religious fanaticism, and Classmates with absurd common sense ...</p><p class=\"bb_paragraph\" >Meeting classmates and teachers with unique personalities at the start of the semester, can she get used to school life from now on?</p><h2 class=\"bb_tag\" ><strong>【Controls】</strong></h2><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3326920/extras/bdd67ffb76f3c890754c321ca31f341b.avif?t=1762827506\" width=600 height=439 /></span>▲Game Objective: Players must increase their intelligence and stamina to at least 20 within 20 days!</p><p class=\"bb_paragraph\" >  </p><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3326920/extras/12ee925355d8b0aebc24cddece4c0105.poster.avif?t=1762827506\" width=600 height=458 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3326920/extras/12ee925355d8b0aebc24cddece4c0105.webm?t=1762827506\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3326920/extras/12ee925355d8b0aebc24cddece4c0105.mp4?t=1762827506\" type=\"video/mp4\"></video></span></p><p class=\"bb_paragraph\" >▲Use arrow keys to control Natsumi and use the Z key to interact with classmates and teachers!</p><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3326920/extras/b083b97e684d422a0fde841e2f89a0f2.poster.avif?t=1762827506\" width=600 height=458 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3326920/extras/b083b97e684d422a0fde841e2f89a0f2.webm?t=1762827506\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3326920/extras/b083b97e684d422a0fde841e2f89a0f2.mp4?t=1762827506\" type=\"video/mp4\"></video></span></p><p class=\"bb_paragraph\" >▲Attend classes and increase knowledge!<br>Although sometimes it might be a self-study period ...?</p><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3326920/extras/b75039e8bbd02e8031c532d0841d677d.avif?t=1762827506\" width=600 height=460 /></span></p><p class=\"bb_paragraph\" >▲Because this is an absurd academy, sparring with classmates is a compulsory subject!</p><p class=\"bb_paragraph\" ></p><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3326920/extras/b6ad5f1a445b607cc7b5f1f62ad4c753.avif?t=1762827506\" width=600 height=454 /></span></p><p class=\"bb_paragraph\" >▲Utilize each function in the academy to its best to improve your abilities!</p><h2 class=\"bb_tag\" ><strong>【Protagonist】</strong></h2><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3326920/extras/6d0d79ef46176f25cd6085d2f16c5b90.avif?t=1762827506\" width=254 height=252 /></span></p><p class=\"bb_paragraph\" >▲Natsumi</p><p class=\"bb_paragraph\" >A normal girl. She is living with her granny because her father is working abroad.She just transferred to a new school and is quite nervous.</p><h2 class=\"bb_tag\" ><strong>【Side Characters】</strong></h2><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3326920/extras/e710bf3bf944b8f21b5261576c7f392d.avif?t=1762827506\" width=600 height=438 /></span></p>", "short_description": "Natsumi meets classmates and teachers with unique personalities at the start of the semester, can she get used to school life from now on?", "supported_languages": "Japanese, English, Simplified Chinese, Traditional Chinese", "header_image": "https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3326920/ccb9c950e666c865483670e2a32b0d89b5c72433/header.jpg?t=1762827506", "capsule_image": "https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3326920/29d66e6bf42ca3d2d3c0219d84963fc203127d4e/capsule_231x87.jpg?t=1762827506", "capsule_imagev5": "https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3326920/29d66e6bf42ca3d2d3c0219d84963fc203127d4e/capsule_184x69.jpg?t=1762827506", "website": "https://072project.com/?source=steam_natsumi_academy&amp;utm_source=steam&amp;utm_medium=natsumi_academy&amp;utm_campaign=store_link", "pc_requirements": {"minimum": "<strong>Minimum:</strong><br><ul class=\"bb_ul\"><li><strong>OS *:</strong> Windows® 7/8/8.1/10/11<br></li><li><strong>Processor:</strong> Intel Core2 Duo or better<br></li><li><strong>Graphics:</strong> DirectX 9/OpenGL 4.1 capable GPU<br></li><li><strong>Storage:</strong> 2 GB available space</li></ul>", "recommended": "<strong>Recommended:</strong><br><ul class=\"bb_ul\"><li><strong>OS *:</strong> Windows® 7/8/8.1/10/11<br></l