2a8b48.poster.avif?t=1769150542\" width=800 height=445 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3044740/extras/db1c7a2bd267311b568e5565a42a8b48.webm?t=1769150542\" type=\"video/webm; codecs=vp9\"></video></span></p><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline crossorigin=\"anonymous\" poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3044740/extras/a1f5fd528045fd9af72b3a102dc75839.poster.avif?t=1769150542\" width=800 height=451 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3044740/extras/a1f5fd528045fd9af72b3a102dc75839.webm?t=1769150542\" type=\"video/webm; codecs=vp9\"></video></span></p><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3044740/extras/bb719705a7748d50f5a7bac754940446.poster.avif?t=1769150542\" width=800 height=452 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3044740/extras/bb719705a7748d50f5a7bac754940446.webm?t=1769150542\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3044740/extras/bb719705a7748d50f5a7bac754940446.mp4?t=1769150542\" type=\"video/mp4\"></video></span> </p><ul class=\"bb_ul\"><li><p class=\"bb_paragraph\" >Exquisite fully animated H scenes </p></li><li><p class=\"bb_paragraph\" >25 H scenes </p></li><li><p class=\"bb_paragraph\" >More than 180 CGs including variants</p></li><li><p class=\"bb_paragraph\" >Interactive CG in dynamic</p></li><li><p class=\"bb_paragraph\" >Three-line parallel development system</p></li><li><p class=\"bb_paragraph\" >Full voice acting for the female lead </p></li><li><p class=\"bb_paragraph\" >Dress-up system </p></li><li><p class=\"bb_paragraph\" >Over 150,000 words of text</p><p class=\"bb_paragraph\" ></p></li></ul><h2 class=\"bb_tag\" >【Game System】</h2><h2 class=\"bb_tag\" ><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3044740/extras/a8115f0050cb0d5836dcf45794bce96b.avif?t=1769150542\" data-big-src=https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3044740/extras_big/a8115f0050cb0d5836dcf45794bce96b.avif?t=1769150542 width=800 height=450 /></span>  </h2><p class=\"bb_paragraph\" ></p><p class=\"bb_paragraph\" ><strong>-Abundant Nurturing System-</strong></p><p class=\"bb_paragraph\" >Players need to arrange the weekly schedules for the three heroines according to their abilities and goals within a year in the game, while paying attention to their physical and mental health. If players fail to relieve their stress in time, irreversible and significant consequences will occur...</p><p class=\"bb_paragraph\" ><strong>Special Date System:</strong> Fulfilling specific conditions before a designated date, such as the heroine's birthday, Christmas, or Tanabata, can trigger special storylines!</p><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3044740/extras/ef367b63362e658d0e463ca826d12a2d.avif?t=1769150542\" data-big-src=https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3044740/extras_big/ef367b63362e658d0e463ca826d12a2d.avif?t=1769150542 width=800 height=450 /></span></p><p class=\"bb_paragraph\" ></p><p class=\"bb_paragraph\" ><strong>-Ultra-realistic Live Streaming Scenes-</strong></p><p class=\"bb_paragraph\" >With Live2D model and realistic live streaming room settings, players can experience ultra-realistic live streaming. </p><p class=\"bb_paragraph\" >VTubers will encounter various unexpected events during live streams, and players need to provide appropriate action suggestions based on the heroines' characteristics!</p><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3044740/extras/b8d296c23652951c122d31e698e1ae2d.avif?t=1769150542\" data-big-src=https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3044740/extras_big/b8d296c23652951c122d31e698e1ae2d.avif?t=1769150542 width=800 height=450 /></span></p><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3044740/extras/851120d2ddcbf68db164c4610973cbd7.poster.avif?t=1769150542\" width=616 height=422 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3044740/extras/851120d2ddcbf68db164c4610973cbd7.webm?t=1769150542\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3044740/extras/851120d2ddcbf68db164c4610973cbd7.mp4?t=1769150542\" type=\"video/mp4\"></video></span></p><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3044740/extras/c00092c62598c39bd751ed5d3b4fbe06.poster.avif?t=1769150542\" width=616 height=422 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3044740/extras/c00092c62598c39bd751ed5d3b4fbe06.webm?t=1769150542\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3044740/extras/c00092c62598c39bd751ed5d3b4fbe06.mp4?t=1769150542\" type=\"video/mp4\"></video></span></p><p class=\"bb_paragraph\" ></p><p class=\"bb_paragraph\" ><strong>-Master of Time Management-</strong></p><p class=\"bb_paragraph\" >To synchronize the nurturing of three VTubers, you need to allocate action points wisely and choose which heroine's growth to witness. </p><p class=\"bb_paragraph\" >Each training session is accompanied by a corresponding mini-game, and the VTubers can also grow rapidly when you perform well!</p><p class=\"bb_paragraph\" ></p><h2 class=\"bb_tag\" >【Character Introduction】</h2><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3044740/extras/3d71270c2b5e4e5fc5032d6f5d1ae7d8.poster.avif?t=1769150542\" width=616 height=422 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3044740/extras/3d71270c2b5e4e5fc5032d6f5d1ae7d8.webm?t=1769150542\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3044740/extras/3d71270c2b5e4e5fc5032d6f5d1ae7d8.mp4?t=1769150542\" type=\"video/mp4\"></video></span></p><h2 class=\"bb_tag\" > </h2><p class=\"bb_paragraph\" >Name of the person behind the character: Kuronuma Yui</p><p class=\"bb_paragraph\" >VTuber Name: Lilith Succubus</p><p class=\"bb_paragraph\" >Age: 25</p><p class=\"bb_paragraph\" >Height: 180 cm</p><p class=\"bb_paragraph\" >Cup Size: G</p><p class=\"bb_paragraph\" >Birthday: July 12</p><p class=\"bb_paragraph\" >An introverted and socially anxious otaku girl, she is a VTuber who is particularly outspoken and bold during live streams. She craves fans' attention and values interaction and cultivated many gachis. She admires the cheerful and confident demeanor of Inuyama Ai, the popular VTuber of Big Mountain Production. </p><p class=\"bb_paragraph\" >The reason for her inferiority complex and introverted personality is due to a certain event she keeps hidden deep within her heart. Her personality becomes particularly assertive and bold during sex. She likes to be in a dominant position and enjoys trying out different props and scenarios...</p><p class=\"bb_paragraph\" ></p><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3044740/extras/eb4b42b108121011e2fb8d50755c737d.poster.avif?t=1769150542\" width=616 height=422 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3044740/extras/eb4b42b108121011e2fb8d50755c737d.webm?t=1769150542\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3044740/extras/eb4b42b108121011e2fb8d50755c737d.mp4?t=1769150542\" type=\"video/mp4\"></video></span></p><p class=\"bb_paragraph\" >Name of the person behind the character: Hinata Junko</p><p class=\"bb_paragraph\" >VTuber Name: Hyou Aoi</p><p class=\"bb_paragraph\" >Age: 21</p><p class=\"bb_paragraph\" >Height: 159 cm</p><p class=\"bb_paragraph\" >Cup Size: F</p><p class=\"bb_paragraph\" >Birthday: August 20</p><p class=\"bb_paragraph\" >A sunny and outgoing university freshman gyaru. She is a sisterly chat-type VTuber, and fans see her as a healing ray of sunshine, while entering the production to escape unknown predicaments. </p><p class=\"bb_paragraph\" >Not very familiar with otaku culture, she sometimes makes funny mistakes, so she is happy to be educated by the viewers. However, she is intentionally taught naughty things. Although she looks like a gyaru, she is surpisingly very pure...</p><p class=\"bb_paragraph\" ></p><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3044740/extras/c1a729eea296a11294e33beb63b3e263.poster.avif?t=1769150542\" width=616 height=422 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3044740/extras/c1a729eea296a11294e33beb63b3e263.webm?t=1769150542\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3044740/extras/c1a729eea296a11294e33beb63b3e263.mp4?t=1769150542\" type=\"video/mp4\"></video></span></p><p class=\"bb_paragraph\" >Name of the person behind the character: Inoue Sanae</p><p class=\"bb_paragraph\" >VTuber Name: Sister Trisha</p><p class=\"bb_paragraph\" >Age: 35</p><p class=\"bb_paragraph\" >Height: 166 cm</p><p class=\"bb_paragraph\" >Cup Size: H</p><p class=\"bb_paragraph\" >Birthday: November 25</p><p class=\"bb_paragraph\" >A seriously clumsy nurture-type VTuber who earnestly replies to every viewer's comments and opinions. Her unique personality charm has attracted many caring, directive-type fans, and her dedication to improving in areas where she is not proficient is moving. Despite not being so young, she chooses to become a VTuber to fulfill her dreams. </p><p class=\"bb_paragraph\" >She appears to be a mature married woman living a stable and smooth life, but inside, she seems to be suffering due to certain reasons. She is usually gentle and serious, but her sexual desire is actually very strong, and she longs for exciting, rough sex...</p>", "about_the_game": "<h2 class=\"bb_tag\" >【Game Overview】</h2><p class=\"bb_paragraph\" >You are a university freshman who loves watching VTuber live streams. You entered Big Mountain Production by chance and became a manager, meeting three unique VTubers and the actual person behind the character. Over the next year, lead them towards the path of realizing their dreams! </p><p class=\"bb_paragraph\" >In addition to working hard to earn money and managing channels, you can also leverage your reliable charm as a manager to gradually enter the hearts of the three girls, even developing relationships with them that goes beyond &quot;VTuber and manager&quot;!</p><p class=\"bb_paragraph\" ></p><h2 class=\"bb_tag\" >【Game Features】</h2><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline crossorigin=\"anonymous\" poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3044740/extras/db1c7a2bd267311b568e5565a42a8b48.poster.av