apps/3201440/extras/9fd7a8349d932b5d545c18de4635c945.poster.avif?t=1774188236\" width=616 height=346 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3201440/extras/9fd7a8349d932b5d545c18de4635c945.webm?t=1774188236\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3201440/extras/9fd7a8349d932b5d545c18de4635c945.mp4?t=1774188236\" type=\"video/mp4\"></video></span></p><h2 class=\"bb_tag\" ><strong><i><u>ANIMATED H SCENE</u></i></strong></h2><p class=\"bb_paragraph\" >Every H-scene in the game is meticulously <strong>hand-animated frame by frame</strong>—no motion tweening—giving each moment a rich, expressive, and handcrafted feel.</p><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3201440/extras/0a86bdbde11c6671e5656b3678164bdc.poster.avif?t=1774188236\" width=616 height=346 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3201440/extras/0a86bdbde11c6671e5656b3678164bdc.webm?t=1774188236\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3201440/extras/0a86bdbde11c6671e5656b3678164bdc.mp4?t=1774188236\" type=\"video/mp4\"></video></span></p><p class=\"bb_paragraph\" >And thanks to this technique, we can create continuous H-scenes that feel truly alive—each moment flowing naturally </p><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3201440/extras/d3dd1622e759595e5bfff5461e64d7ed.poster.avif?t=1774188236\" width=616 height=346 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3201440/extras/d3dd1622e759595e5bfff5461e64d7ed.webm?t=1774188236\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3201440/extras/d3dd1622e759595e5bfff5461e64d7ed.mp4?t=1774188236\" type=\"video/mp4\"></video></span></p><p class=\"bb_paragraph\" ></p><h2 class=\"bb_tag\" ><strong><i><u>GAME SYSTEM</u></i></strong></h2><h2 class=\"bb_tag\" ><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3201440/extras/ac66d02b1f2ac786508c357ffbfe3f07.avif?t=1774188236\" data-big-src=https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3201440/extras_big/ac66d02b1f2ac786508c357ffbfe3f07.avif?t=1774188236 width=800 height=146 /></span></h2><p class=\"bb_paragraph\" >We've added a gallery system in this version, making it easier for players to access cutscenes and animation scenes. You can unlock new cutscenes and animations by playing the game and discovering them.</p><p class=\"bb_paragraph\" ></p><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3201440/extras/d16f01a54b056c3cd67dfbf56ac00a02.avif?t=1774188236\" data-big-src=https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3201440/extras_big/d16f01a54b056c3cd67dfbf56ac00a02.avif?t=1774188236 width=800 height=146 /></span></p><p class=\"bb_paragraph\" >We've also included a cheat code system, </p><p class=\"bb_paragraph\" ></p><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3201440/extras/f619c10f8971f2e3664ee3e08693c0ff.avif?t=1774188236\" data-big-src=https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3201440/extras_big/f619c10f8971f2e3664ee3e08693c0ff.avif?t=1774188236 width=800 height=146 /></span></p><p class=\"bb_paragraph\" >🗺️ <strong>Map Feature</strong> – Now you can explore even more areas with the new map system, allowing you to travel between locations seamlessly. 🌍</p><p class=\"bb_paragraph\" ></p><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3201440/extras/7c8436533e681ff7fa01b14144f5b81c.avif?t=1774188236\" data-big-src=https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3201440/extras_big/7c8436533e681ff7fa01b14144f5b81c.avif?t=1774188236 width=800 height=146 /></span></p><p class=\"bb_paragraph\" >🔮 <strong>Guide Vision</strong> – Easily find interactive objects with the new Guide Vision system. No more missing out on hidden secrets! 🌟</p><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3201440/extras/56b056907042840de8b1f038262ecd93.avif?t=1774188236\" data-big-src=https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3201440/extras_big/56b056907042840de8b1f038262ecd93.avif?t=1774188236 width=800 height=124 /></span></p><p class=\"bb_paragraph\" ><strong>Day System: </strong></p><p class=\"bb_paragraph\" >The Day system is a significant addition to the game. It plays a crucial role in influencing events and interactions. When your character sleeps or certain in-game events occur, the day may change. Additionally, some character meetings and quests will now require you to be in the right location on the correct day, adding a new layer of realism and strategy to your gameplay</p><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3201440/extras/8333e126e8e6ddf51263a9c7f70de313.avif?t=1774188236\" data-big-src=https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3201440/extras_big/8333e126e8e6ddf51263a9c7f70de313.avif?t=1774188236 width=800 height=124 /></span></p><p class=\"bb_paragraph\" ><strong>Time System: </strong></p><p class=\"bb_paragraph\" >Our Time system is another exciting feature that adds depth to your gaming experience. Time will now pass as you progress through the game and encounter various events. This dynamic element will impact how you approach challenges and decisions, making the game world feel more alive and responsive to your actions.</p><p class=\"bb_paragraph\" ></p><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3201440/extras/b98d0ac28e4e0c664262ac44d656f346.avif?t=1774188236\" data-big-src=https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3201440/extras_big/b98d0ac28e4e0c664262ac44d656f346.avif?t=1774188236 width=800 height=146 /></span></p><p class=\"bb_paragraph\" ><strong>Hint System (Improvement) :</strong></p><p class=\"bb_paragraph\" >We've significantly upgraded the quest system, making it easier for players to complete quests. The hint system has also been overhauled to be clearer, more understandable, and more player-friendly.</p><p class=\"bb_paragraph\" ></p><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3201440/extras/e93ddcb0ce8ed572f6f6080269f7cf8a.avif?t=1774188236\" data-big-src=https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3201440/extras_big/e93ddcb0ce8ed572f6f6080269f7cf8a.avif?t=1774188236 width=800 height=146 /></span></p><p class=\"bb_paragraph\" >The Inventory system has been added in this update. It will now provide you with a clear view of the items you possess. This will be especially useful when you need to use specific items to complete quests or overcome obstacles. </p><p class=\"bb_paragraph\" ></p>", "about_the_game": "<p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3201440/extras/cdc1cb1244de75b74872a1c878ad74f5.avif?t=1774188236\" data-big-src=https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3201440/extras_big/cdc1cb1244de75b74872a1c878ad74f5.avif?t=1774188236 width=800 height=450 /></span></p><h2 class=\"bb_tag\" ><strong><i><u>GAME STORY</u></i></strong></h2><p class=\"bb_paragraph\" >The game<strong> &quot;My place is cursed&quot;</strong> is about a <strong>man</strong> who <strong>becomes the manager</strong> of his grandfather's apartment building, where <strong>strange and unusual occurrences begin</strong> to happen. However, amidst the strange happenings, meet various experiences, such as meeting the girls in the building and forming a relationship with them. The next part of the<strong> story is up to you</strong>, as the player, to decide how it will end.</p><p class=\"bb_paragraph\" ></p><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3201440/extras/9fd7a8349d932b5d545c18de4635c945.poster.avif?t=1774188236\" width=616 height=346 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3201440/extras/9fd7a8349d932b5d545c18de4635c945.webm?t=1774188236\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3201440/extras/9fd7a8349d932b5d545c18de4635c945.mp4?t=1774188236\" type=\"video/mp4\"></video></span></p><h2 class=\"bb_tag\" ><strong><i><u>ANIMATED H SCENE</u></i></strong></h2><p class=\"bb_paragraph\" >Every H-scene in the game is meticulously <strong>hand-animated frame by frame</strong>—no motion tweening—giving each moment a rich, expressive, and handcrafted feel.</p><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3201440/extras/0a86bdbde11c6671e5656b3678164bdc.poster.avif?t=1774188236\" width=