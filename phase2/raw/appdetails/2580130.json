c85bda77a4115843343.webm?t=1770041850\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2580130/extras/9b14a44947ad6c85bda77a4115843343.mp4?t=1770041850\" type=\"video/mp4\"></video></span></p><p class=\"bb_paragraph\" >Who did you choose as your allies? How do others view you?</p><p class=\"bb_paragraph\" ></p><p class=\"bb_paragraph\" >Continue your story by importing your choices from The Seven Realms: Terran &amp; Pythonium.</p><p class=\"bb_paragraph\" ></p><p class=\"bb_paragraph\" >Or start a brand new journey here with an immersive recap and save simulation, allowing you to jump straight into the Elven Realm. </p><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2580130/extras/819c1bec18e8835f8c8cad62ba5459d6.poster.avif?t=1770041850\" width=600 height=250 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2580130/extras/819c1bec18e8835f8c8cad62ba5459d6.webm?t=1770041850\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2580130/extras/819c1bec18e8835f8c8cad62ba5459d6.mp4?t=1770041850\" type=\"video/mp4\"></video></span></p><p class=\"bb_paragraph\" >Your choices will influence the future of the realms and impact those you love.</p><p class=\"bb_paragraph\" ></p><p class=\"bb_paragraph\" >What kind of partner, ally and ruler will you be? Start your adventure now!</p><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2580130/extras/6fdb7d9ea03873c3963fc572a5b5eff0.avif?t=1770041850\" width=600 height=174 /></span></p><p class=\"bb_paragraph\" >High Lathión is playable on Steam Deck and compatible with PlayStation and Xbox  controllers.</p>", "about_the_game": "<p class=\"b