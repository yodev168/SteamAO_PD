f6c7f69e.poster.avif?t=1761891735\" width=800 height=450 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3225060/extras/08854def26c23f87122338a4f6c7f69e.webm?t=1761891735\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3225060/extras/08854def26c23f87122338a4f6c7f69e.mp4?t=1761891735\" type=\"video/mp4\"></video></span><strong>【Game Overview】</strong></h2><p class=\"bb_paragraph\" >▌Live streaming, romance, and a touch of spice!? Welcome to Sweet Succubus Home!</p><p class=\"bb_paragraph\" >Recently laid off and down on his luck, a struggling musician crosses paths with a mysterious girl named Iris. She’s quiet and fragile at first, but with a little care—and a lot of sweets—she bounces back and reveals the truth: she’s a succubus from another world.</p><p class=\"bb_paragraph\" >To survive city life, the two team up for music livestreams. As their performances gain fans, their relationship begins to shift from casual roommates to something far more intimate.</p><p class=\"bb_paragraph\" >But peaceful cohabitation is out of the question. The landlady won’t stop offering unsolicited life advice, the sporty neighbor keeps bursting in uninvited, and a sharp-tongued convenience store clerk seems determined to stir the pot.</p><p class=\"bb_paragraph\" >In this rhythm game meets visual novel, your choices shape the outcome. Can you turn this chaotic, flirt-filled daily life into the sweetest ending?</p><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3225060/extras/46a2552530641dc4cc882c96883ce984.poster.avif?t=1761891735\" width=800 height=450 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3225060/extras/46a2552530641dc4cc882c96883ce984.webm?t=1761891735\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3225060/extras/46a2552530641dc4cc882c96883ce984.mp4?t=1761891735\" type=\"video/mp4\"></video></span></p><h2 class=\"bb_tag\" >【Features】</h2><ul class=\"bb_ul\"><li><p class=\"bb_paragraph\" >Rhythm Gameplay: Classic rhythm action—follow the beat and let’s groove!</p></li><li><p class=\"bb_paragraph\" >Succubus Seduction: Unlock intimate events through engaging systems and get ready for blush-inducing sweetness!</p></li><li><p class=\"bb_paragraph\" >Character Growth: Take on gigs, go shopping, chat, and go on dates to boost your stats and unlock new stories!</p></li><li><p class=\"bb_paragraph\" >Multiple Endings: Your choices shape your path—can you reach the sweetest ending?</p></li><li><p class=\"bb_paragraph\" >Over 25 animated H-scenes and more than 5 beautifully illustrated event CGs!</p></li></ul><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3225060/extras/9bd341944ca14acb930dc912353906a6.poster.avif?t=1761891735\" width=800 height=450 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3225060/extras/9bd341944ca14acb930dc912353906a6.webm?t=1761891735\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3225060/extras/9bd341944ca14acb930dc912353906a6.mp4?t=1761891735\" type=\"video/mp4\"></video></span></p><h2 class=\"bb_tag\" >【Character Introduction】</h2><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3225060/extras/1f215efb97636716ae105e42db1f2e26.poster.avif?t=1761891735\" width=800 height=450 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3225060/extras/1f215efb97636716ae105e42db1f2e26.webm