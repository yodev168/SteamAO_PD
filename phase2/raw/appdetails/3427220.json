a2.poster.avif?t=1774514373\" width=800 height=450 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3427220/extras/faa91e64c9e32d8be9530adac6bfa9a2.webm?t=1774514373\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3427220/extras/faa91e64c9e32d8be9530adac6bfa9a2.mp4?t=1774514373\" type=\"video/mp4\"></video></span></p><p class=\"bb_paragraph\" >敵人發情了！</p><p class=\"bb_paragraph\" >大家都盯上了琪塔！如果無法在戰鬥時打倒敵人，琪塔就會陷入險境！</p><p class=\"bb_paragraph\" >華麗的視覺表現！</p><p class=\"bb_paragraph\" >結合了3DCG和LIVE2D、精心製作的動畫！身體各個部位都能搖晃、抖動！</p><p class=\"bb_paragraph\" >進行探險就能提升等級！</p><p class=\"bb_paragraph\" >使用技能點數進行強化！</p><p class=\"bb_paragraph\" >戰鬥贏得勝利時，即可獲得新的戰鬥物品配方！</p><p class=\"bb_paragraph\" >提升熟練度就能解鎖更強大的物品！</p><p class=\"bb_paragraph\" >武器引擎會隨機升級！</p><p class=\"bb_paragraph\" >善加使用武器，讓武器達到理想的狀態！</p><p class=\"bb_paragraph\" >以SRPG風格呈現乘著機器人作戰的戰鬥畫面！</p><p class=\"bb_paragraph\" >使用收集到的能源改造機體，擊潰追捕琪塔的敵軍！</p><p class=\"bb_paragraph\" >各個項目皆有ON／OFF功能，可自由調整難易度！</p><p class=\"bb_paragraph\" >玩家可自由選擇遊玩方式，可輕鬆觀看劇情，也能進行高難度的探索和戰鬥！</p><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3427220/extras/253e9e7226813613b509ac6d4c841bc4.poster.avif?t=1774514373\" width=800 height=450 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3427220/extras/253e9e7226813613b509ac6d4c841bc4.webm?t=1774514373\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3427220/extras/253e9e7226813613b509ac6d4c841bc4.mp4?t=1774514373\" type=\"video/mp4\"></video></span></p><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3427220/extras/c96a29a5b09ed2af317e042b7495b0d4.avif?t=1774514373\" width=616 height=73 /></span></p><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3427220/extras/064907379e03b342c9f76e30fa2f9a29.poster.avif?t=1774514373\" width=800 height=450 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3427220/extras/064907379e03b342c9f76e30fa2f9a29.webm?t=1774514373\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3427220/extras/064907379e03b342c9f76e30fa2f9a29.mp4?t=1774514373\" type=\"video/mp4\"></video></span></p><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3427220/extras/266ede91ef633421e20d5cce5933145c.poster.avif?t=1774514373\" width=800 height=450 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3427220/extras/266ede91ef633421e20d5cce5933145c.webm?t=1774514373\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3427220/extras/266ede91ef633421e20d5cce5933145c.mp4?t=1774514373\" type=\"video/mp4\"></video></span></p><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3427220/extras/6e60eb374cb1ea475c894de207733bc0.poster.avif?t=1774514373\" width=800 height=450 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3427220/extras/6e60eb374cb1ea475c894de207733bc0.webm?t=1774514373\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3427220/extras/6e60eb374cb1ea475c894de207733bc0.mp4?t=1774514373\" type=\"video/mp4\"></video></span>💠💠【購買前的注意事項】</p><p class=\"bb_paragraph\" >本遊戲使用名為RPGDeveloperBakin的工具製作。</p><p class=\"bb_paragraph\" >操作環境預設為RPGDeveloperBakin的建議環境。</p><p class=\"bb_paragraph\" >建議可先遊玩試玩版，確認遊戲可正常運作後再購買。</p><p class=\"bb_paragraph\" >※AMD生產的CPU(Ryzen)和GPU(Radeon)即使符合建議環境，但仍會產生動畫等部分圖片無法正常顯示等問題。</p><p class=\"bb_paragraph\" ></p>", "short_description": "名為琪塔的少女失去記憶，醒來後發現自己被安置於巨大的機器人內。 莫名其妙成為叛徒，還遭到追捕的琪塔迫降在一座未開發的島嶼。 島上到處都是危險的生物、原住民以及追兵，他們全都衝著琪塔而來！ 為何自己會遭遇如此橫禍？隱藏於這座島的秘密和陰謀，正等著少女揭發。 究竟琪塔是否能安全逃出這座島呢？他的命運，掌握在玩家手上⋯⋯", "supported_languages": "日文<strong>*</strong>, 英文, 簡體中文, 繁體中文<br><strong>*</strong>具備完整音效支援的語言", "header_image": "https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3427220/header_tchinese.jpg?t=1774514373", "capsule_image": "https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3427220/30567cbf4afd0ac7e82115173aa61a634bfb0443/capsule_231x87.jpg?t=1774514373", "capsule_imagev5": "https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3427220/30567cbf4afd0ac7e82115173aa61a634bfb0443/capsule_184x69.jpg?t=1774514373", "website": null, "pc_requirements": {"minimum": "<strong>最低配備:</strong><br><ul class=\"bb_ul\"><li>需要 64 位元的處理器及作業系統<br></li><li><strong>作業系統:</strong> 10 / 11<br></li><li><strong>處理器:</strong> Requires a 64-bit processor and operating system. (Some graphics may not display properly even if the AMD CPU meets the requirements.)<br></li><li><strong>記憶體:</strong> 16 MB 記憶體<br></li><li><strong>顯示卡:</strong> NVIDIA® GeForce™ GTX1650 AMD Radeon™ RX570 (*Even if the AMD GPU meets the requirements, some graphics may not be displayed properly.)</li></ul>", "recommended": "<strong>建議配備:</strong><br><ul class=\"bb_ul\"><li>需要 64 位元的處理器及作業系統</li></ul>"}, "mac_requirements": {"minimum": "<strong>最低配備:</strong><br><ul class=\"bb_ul\"></ul>", "recommended": "<strong>建議配備:</strong><br><ul class=\"bb_ul\"></ul>"}, "linux_requirements": {"minimum": "<strong>最低配備:</strong><br><ul class=\"bb_ul\"></ul>", "recommended": "<strong>建議配備:</strong><br><ul class=\"bb_ul\"></ul>"}, "release_date": {"coming_soon": true, "date": "即將推出"}}}}, "us": {"3427220": {"success": true, "data": {"type": "game", "name": "Chetta: The Machinery Girl", "steam_appid": 3427220, "required_age": 0, "is_free": false, "detailed_description": "<p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3427220/extras/1d4e11c4bc729ad3e4689593d74ab7f9.avif?t=1774514373\" width=616 height=73 /></span></p><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3427220/extras/9661589dc81f560ca929af260ff92f8e.poster.avif?t=1774514373\" width=800 height=450 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3427220/extras/9661589dc81f560ca929af260ff92f8e.webm?t=1774514373\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3427220/extras/9661589dc81f560ca929af260ff92f8e.mp4?t=1774514373\" type=\"video/mp4\"></video></span></p><p class=\"bb_paragraph\" >Chetta, an amnesiac girl, awakens and is forced to pilot a giant robot.</p><p class=\"bb_paragraph\" >Pursued as a rebel for reasons she doesn't comprehend, Chetta crash-lands on an undeveloped island.</p><p class=\"bb_paragraph\" >The island is filled with dangerous creatures, hostile natives, and her pursuers, all of whom are coming after her, in more ways than one…</p><p class=\"bb_paragraph\" >Secrets and conspiracies lie hidden on the island, as if they were waiting for her.</p><p class=\"bb_paragraph\" >Can Chetta escape the island unharmed? Her fate is left to the player…</p><p class=\"bb_paragraph\" ></p><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3427220/extras/f52af42290be03183792837a2b825b31.avif?t=1774514373\" width=616 height=73 /></span><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3427220/extras/149cc6f60d11bc3025d2484bca000ff8.avif?t=1774514373\" width=616 height=275 /></span></p><p class=\"bb_paragraph\" ><strong>Chetta (VA: Fuyusa Nagi)</strong></p><p class=\"bb_paragraph\" >The main character. She was seemingly famed for being a girl genius, but she's currently lost her memory. She was pursued for being a rebel and crash-landed on an undeveloped island. She's cheerful, positive, and not one to let hardship get her down, but it's unclear if this was always her personality.</p><p class=\"bb_paragraph\" ><strong>Lina (Ryoko Tezuka)</strong></p><p class=\"bb_paragraph\" >The captain of the squadron pursuing Chetta. Her impulsivity sometimes creates trouble for the people around her. She seems to have had a deep relationship with Chetta in the past, but Chetta doesn't remember it.</p><p class=\"bb_paragraph\" ><strong>Rabbit</strong></p><p class=\"bb_paragraph\" >The support AI for the MK-L that Chetta pilots. It teaches the amnesiac Chetta various things.</p><p class=\"bb_paragraph\" ></p><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3427220/extras/f7f60f005942af1182c91015da91003b.avif?t=1774514373\" width=616 height=73 /></span></p><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3427220/extras/faa91e64c9e32d8be9530adac6bfa9a2.poster.avif?t=1774514373\" width=800 height=450 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3427220/extras/faa91e64c9e32d8be9530adac6bfa9a2.webm?t=1774514373\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3427220/extras/faa91e64c9e32d8be9530adac6bfa9a2.mp4?t=1774514373\" type=\"video/mp4\"></video></span></p><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3427220/extras/253e9e7226813613b509ac6d4c841bc4.poster.avif?t=1774514373\" width=800 height=450 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3427220/extras/253e9e7226813613b509ac6d4c841bc4.webm?t=1774514373\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3427220/extras/253e9e7226813613b509ac6d4c841bc4.mp4?t=1774514373\" type=\"video/mp4\"></video></span></p><ul class=\"bb_ul\"><li><p class=\"bb_paragraph\" >Tons of horny enemies!</p><p class=\"bb_paragraph\" >Everyone's out to get Chetta! Either skillfully defeat your opponents in battle, or risk letting them have their way with her.</p></li><li><p class=\"bb_paragraph\" >Gorgeous graphics!</p><p class=\"bb_paragraph\" >High-quality animations that mix 3D CG and LIVE 2D graphics! All parts of Chetta's body move, giggle, and bounce! </p></li><li><p class=\"bb_paragraph\" >Level up through exploration!</p><p class=\"bb_paragraph\" >Use skill points to get stronger!</p></li><li><p class=\"bb_paragraph\" >Learn new recipes for crafting battle items as you win fights!</p><p class=\"bb_paragraph\" >You'll come up with stronger items as you refine your skills!</p></li><li><p class=\"bb_paragraph\" >Gears attached to your weapons will improve at random!</p><p class=\"bb_paragraph\" >Use your favorite weapons until you master them!</p></li><li><p class=\"bb_paragraph\" >SRPG-style battles in a robot!</p><p class=\"bb_paragraph\" >Use accumulated energy to upgrade your mech and take down the enemy forces pursuing Chetta!</p></li><li><p class=\"bb_paragraph\" >Difficulty adjustments that allow you to turn various elements on and off!</p><p class=\"bb_paragraph\" >You can play casually and focus on the story, or you can turn up the difficulty to enjoy challenging exploration and combat! It's all up to you!</p></li></ul><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3427220/extras/5b5b1cc970d490346a3240135688204f.avif?t=1774514373\" width=616 height=73 /></span></p><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3427220/extras/064907379e03b342c9f76e30fa2f9a29.poster.avif?t=1774514373\" width=800 height=450 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3427220/extras/064907379e03b342c9f76e30fa2f9a29.webm?t=1774514373\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3427220/extras/064907379e03b342c9f76e30fa2f9a29.mp4?t=1774514373\" type=\"video/mp4\"></video></span></p><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3427220/extras/266ede91ef633421e20d5cce5933145c.poster.avif?t=1774514373\" width=800 height=450 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3427220/extras/266ede91ef633421e20d5cce5933145c.webm?t=1774514373\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3427220/extras/266ede91ef633421e20d5cce5933145c.mp4?t=1774514373\" type=\"video/mp4\"></video></span></p><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3427220/extras/6e60eb374cb1ea475c894de207733bc0.poster.avif?t=1774514373\" width=800 height=450 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3427220/extras/6e60eb374cb1ea475c894de207733bc0.webm?t=1774514373\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3427220/extras/6e60eb374cb1ea475c894de207733bc0.mp4?t=1774514373\" type=\"video/mp4\"></video></span></p><p class=\"bb_paragraph\" >💠💠 Please read carefully before purchase</p><p class=\"bb_paragraph\" >This game was developed using a tool called RPGDeveloperBakin.</p><p class=\"bb_paragraph\" >The minimum PC specs of this game are assumed to be the same as those required to run RPGDeveloperBakin</p><p class=\"bb_paragraph\" >We recommend playing the trial to check how well the game runs on your PC before purchasing the full version.</p><p class=\"bb_paragraph\" >*AMD CPUs (Ryzen) and GPUs (Radeon) may result in errors such as the graphics in animated segments being displayed incorrectly.</p><p class=\"bb_paragraph\" ></p>", "about_the_game": "<p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3427220/extras/1d4e11c4bc729ad3e4689593d74ab7f9.avif?t=1774514373\" width=616 height=73 /></span></p><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3427220/extras/9661589dc81f560ca929af260ff92f8e.poster.avif?t=1774514373\" width=800 height=450 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3427220/extras/9661589dc81f560ca929af260ff92f8e.webm?t=1774514373\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3427220/extras/9661589dc81f560ca929af260ff92f8e.mp4?t=1774514373\" type=\"video/mp4\"></video></span></p><p class=\"bb_paragraph\" >Chetta, an amnesiac girl, awakens and is forced to pilot a giant robot.</p><p class=\"bb_paragraph\" >Pursued as a rebel for reasons she doesn't comprehend, Chetta crash-lands on an undeveloped island.</p><p class=\"bb_paragraph\" >The island is filled with dangerous creatures, hostile natives, and her pursuers, all of whom are coming after her, in more ways than one…</p><p class=\"bb_paragraph\" >Secrets and conspiracies lie hidden on the island, as if they were waiting for her.</p><p class=\"bb_paragraph\" >Can Chetta escape the island unharmed? Her fate is left to the player…</p><p class=\"bb_paragraph\" ></p><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3427220/extras/f52af42290be03183792837a2b825b31.avif?t=1774514373\" width=616 height=73 /></span><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3427220/extras/149cc6f60d11bc3025d2484bca000ff8.avif?t=1774514373\" width=616 height=275 /></span></p><p class=\"bb_paragraph\" ><strong>Chetta (VA: Fuyusa Nagi)</strong></p><p class=\"bb_paragraph\" >The main character. She was seemingly famed for being a girl genius, but she's currently lost her memory. She was pursued for being a rebel and crash-landed on an undeveloped island. She's cheerful, positive, and not one to let hardship get her down, but it's unclear if this was always her personality.</p><p class=\"bb_paragraph\" ><strong>Lina (Ryoko Tezuka)</strong></p><p class=\"bb_paragraph\" >The captain of the squadron pursuing Chetta. Her impulsivity sometimes creates trouble for the people around her. She seems to have had a deep relationship with Chetta in the past, but Chetta doesn't remember it.</p><p class=\"bb_paragraph\" ><strong>Rabbit</strong></p><p class=\"bb_paragraph\" >The support AI for the MK-L that Chetta pilots. It teaches the amnesiac Chetta various things.</p><p class=\"bb_paragraph\" ></p><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3427220/extras/f7f60f005942af1182c91015da91003b.avif?t=1774514373\" width=616 height=73 /></span></p><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3427220/extras/faa91e64c9e32d8be9530adac6bfa9a2.poster.avif?t=1774514373\" width=800 height=450 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3427220/extras/faa91e64c9e32d8be9530adac6bfa9a2.webm?t=1774514373\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3427220/extras/faa91e64c9e32d8be9530adac6bfa9a2.mp4?t=1774514373\" type=\"video/mp4\"></video></span></p><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3427220/extras/253e9e7226813613b509ac6d4c841bc4.poster.avif?t=1774514373\" width=800 height=450 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3427220/extras/253e9e7226813613b509ac6d4c841bc4.webm?t=1774514373\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3427220/extras/253e9e7226813613b509ac6d4c841bc4.mp4?t=1774514373\" type=\"video/mp4\"></video></span></p><ul class=\"bb_ul\"><li><p class=\"bb_paragraph\" >Tons of horny enemies!</p><p class=\"bb_paragraph\" >Everyone's out to get Chetta! Either skillfully defeat your opponents in battle, or risk letting them have their way with her.</p></li><li><p class=\"bb_paragraph\" >Gorgeous graphics!</p><p class=\"bb_paragraph\" >High-quality animations that mix 3D CG and LIVE 2D graphics! All parts of Chetta's body move, giggle, and bounce! </p></li><li><p class=\"bb_paragraph\" >Level up through exploration!</p><p class=\"bb_paragraph\" >Use skill points to get stronger!</p></li><li><p class=\"bb_paragraph\" >Learn new recipes for crafting battle items as you win fights!</p><p class=\"bb_paragraph\" >You'll come up with stronger items as you refine your skills!</p></li><li><p class=\"bb_paragraph\" >Gears attached to your weapons will improve at random!</p><p class=\"bb_paragraph\" >Use your favorite weapons until you master them!</p></li><li><p class=\"bb_paragraph\" >SRPG-style battles in a robot!</p><p class=\"bb_paragraph\" >Use accumulated energy to upgrade your mech and take down the enemy forces pursuing Chetta!</p></li><li><p class=\"bb_paragraph\" >Difficulty adjustments that allow you to turn various elements on and off!</p><p class=\"bb_paragraph\" >You can play casually and focus on the story, or you can turn up the difficulty to enjoy challenging exploration and combat! It's all up to you!</p></li></ul><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3427220/extras/5b5b1cc970d490346a3240135688204f.avif?t=1774514373\" width=616 height=73 /></span></p><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3427220/extras/064907379e03b342c9f76e30fa2f9a29.poster.avif?t=1774514373\" width=800 height=450 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3427220/extras/064907379e03b342c9f76e30fa2f9a29.webm?t=1774514373\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3427220/extras/064907379e03b342c9f76e30fa2f9a29.mp4?t=1774514373\" type=\"video/mp4\"></video></span></p><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_i