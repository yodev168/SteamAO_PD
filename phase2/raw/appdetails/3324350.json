749ec9989b9d358e13fb9ce21f9c2885.webm?t=1761813591\" type=\"video/webm; codecs=vp9\"></video></span><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline crossorigin=\"anonymous\" poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3324350/extras/1cac5aa956b3df091b2722f000c4d755.poster.avif?t=1761813591\" width=1170 height=853 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3324350/extras/1cac5aa956b3df091b2722f000c4d755.webm?t=1761813591\" type=\"video/webm; codecs=vp9\"></video></span><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline crossorigin=\"anonymous\" poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3324350/extras/f99dda3ab840849340e884eeb0050792.poster.avif?t=1761813591\" width=1170 height=894 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3324350/extras/f99dda3ab840849340e884eeb0050792.webm?t=1761813591\" type=\"video/webm; codecs=vp9\"></video></span></p><p class=\"bb_paragraph\" ></p><p class=\"bb_paragraph\" ></p><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3324350/extras/c9372a1a2b891b8c6329a8c3c0db3f59.avif?t=1761813591\" width=600 height=329 /></span></p><p class=\"bb_paragraph\" ></p><p class=\"bb_paragraph\" ></p><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3324350/extras/f6fecc511998ad22e3d99cf2ec30a63c.avif?t=1761813591\" width=600 height=348 /></span></p><p class=\"bb_paragraph\" ></p><p class=\"bb_paragraph\" ></p><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3324350/extras/291a74185042cdab25d23fcaf8e3e99f.avif?t=1761813591\" width=600 height=325 /></span></p><p class=\"bb_paragraph\" ></p><p class=\"bb_paragraph\" ></p><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3324350/extras/b2342282b143245473530e5900ae8e12.avif?t=1761813591\" width=600 height=383 /></span></p><p class=\"bb_paragraph\" ></p><p class=\"bb_paragraph\" ></p><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3324350/extras/ed3fd4a68061b83f7067aa16173805cd.avif?t=1761813591\" width=600 height=386 /></span></p><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3324350/extras/d68cbd83bed81e50c5fdb210ff638ac7.avif?t=1761813591\" width=600 height=355 /></span></p><p class=\"bb_paragraph\" ></p><p class=\"bb_paragraph\" ></p><p class=\"bb_paragraph\" ><strong>牌型介紹：</strong></p><ul class=\"bb_ul\"><li><p class=\"bb_paragraph\" >單張：單張牌，例如A。</p></li><li><p class=\"bb_paragraph\" >對子：兩張相同點數的牌，例如KK。</p></li><li><p class=\"bb_paragraph\" >連對：兩組或以上的連續對子，例如3344。</p></li><li><p class=\"bb_paragraph\" >順子：五張或更多連續的單張，例如34567（不包含2）。</p></li><li><p class=\"bb_paragraph\" >三張：三張點數相同的牌，例如QQQ。</p></li><li><p class=\"bb_paragraph\" >連三張：兩組或以上連續的三張，例如333444555（不包含2）。</p></li><li><p class=\"bb_paragraph\" >炸彈：四張或更多點數相同的牌，例如6666。</p></li><li><p class=\"bb_paragraph\" >連炸彈：兩組或以上的連續炸彈，例如6666677777。</p></li><li><p class=\"bb_paragraph\" ></p></li></ul><p class=\"bb_paragraph\" ><strong>攻擊力計算方式：</strong></p><ul class=\"bb_ul\"><li><p class=\"bb_paragraph\" >數字牌的攻擊力等於牌的點數。J、Q、K的攻擊力為10，A的攻擊力為11。</p></li><li><p class=\"bb_paragraph\" >牌型中的所有牌都會造成傷害。</p></li></ul><p class=\"bb_paragraph\" >實際攻擊力 = （牌型中所有牌的攻擊力總和 + 牌型的基礎攻擊力）× 牌型的攻擊倍數。</p>", "about_the_game": "<p class=\"bb_paragraph\" >主公！組好你的手牌，擊敗各路勢力（搶人妻），成為三國霸主！這就是你的使命啦！</p><p class=\"bb_paragraph\" >在遊戲中，你將根據手中的卡牌組成特定牌型打出，對敵人造成傷害！</p><p class=\"bb_paragraph\" >擊敗敵人後，他們就能被你收為部下（後宮）啦！</p><p class=\"bb_paragraph\" ></p><p class=\"bb_paragraph\" >🔥 <strong>爆衣系統</strong><br>每位角色都搭載了爆衣系統，在遊戲過程中，角色會隨著關卡推進，切換到 <strong>爆衣1階段</strong> 和 <strong>爆衣2階段</strong>。</p><p class=\"bb_paragraph\" >下方是部分角色的爆衣展示效果圖：</p><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline crossorigin=\"anonymous\" poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3324350/extras/013a32430f82789aedb86f3b4bdccab3.poster.avif?t=1761813591\" width=1170 height=649 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3324350/extras/013a32430f82789aedb86f3b4bdccab3.webm?t=1761813591\" type=\"video/webm; codecs=vp9\"></video></span></p><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline crossorigin=\"anonymous\" poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3324350/extras/0afdca41fc704f452213de131610ce8e.poster.avif?t=1761813591\" width=1170 height=649 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3324350/extras/0afdca41fc704f452213de131610ce8e.webm?t=1761813591\" type=\"video/webm; codecs=vp9\"></video></span></p><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline crossorigin=\"anonymous\" poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3324350/extras/4cfa3882804c87314c47c6503439832d.poster.avif?t=1761813591\" width=1170 height=649 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3324350/extras/4cfa3882804c87314c47c6503439832d.webm?t=1761813591\" type=\"video/webm; codecs=vp9\"></video></span></p><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline crossorigin=\"anonymous\" poster=\"https://shared.akamai.steamstatic.com/store_item_assets/stea